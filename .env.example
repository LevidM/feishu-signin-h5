# 飞书应用凭证（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 签到页面基础URL（插件生成链接时使用）
# 开发环境：留空自动使用当前域名
# 生产环境：设置为你的 H5 签到系统访问地址
# 示例：https://event.fszi.org
SIGNIN_BASE_URL=https://event.fszi.org

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 可选：跨域白名单，多个域名用英文逗号分隔。
# H5 与 API 同域部署时可留空。
ALLOWED_ORIGINS=

# Redis 缓存与分布式锁。
# 生产建议配置 redis；本地开发可留空自动回退内存缓存。
CACHE_BACKEND=auto
REDIS_URL=redis://:你的Redis密码@127.0.0.1:6379/0

# 活动签到缓存策略。
# 默认 6 小时，适合报名截止后的一场活动；未命中最多每 60 秒刷新一次。
CONFIG_CACHE_TTL=21600
RECORD_CACHE_TTL=21600
MISS_REFRESH_COOLDOWN=60
